---
import ThemeToggle from "./ThemeToggle.astro";
import { withBase, withoutBase } from "../lib/paths";

const navItems = [
  ["个人资料", "/about/"],
  ["成长路线", "/growth/"],
  ["项目档案", "/projects/"],
  ["文章归档", "/articles/"],
];

const pathname = withoutBase(Astro.url.pathname);
---

<header class="site-header">
  <div class="site-shell header-inner">
    <a class="brand" href={withBase("/")} aria-label="回到首页">
      <strong>Houraiji</strong>
      <span>AI 应用开发 · RAG · Agent · 成长存档</span>
    </a>
    <nav class="nav" aria-label="主导航">
      {navItems.map(([label, href]) => (
        <a href={withBase(href)} aria-current={pathname === href ? "page" : undefined}>{label}</a>
      ))}
    </nav>
    <ThemeToggle />
  </div>
</header>
