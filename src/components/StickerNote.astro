---
import { withBase } from "../lib/paths";

const {
  src,
  title,
  caption = "",
  tone = "soft",
  class: className = "",
} = Astro.props;
const imageSrc = withBase(src);
---

<div class:list={["sticker-note", `tone-${tone}`, className]}>
  <img src={imageSrc} alt={title} />
  <div>
    <strong>{title}</strong>
    {caption && <span>{caption}</span>}
  </div>
</div>
