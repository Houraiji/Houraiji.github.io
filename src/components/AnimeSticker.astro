---
const { label = "Archive Buddy", compact = false } = Astro.props;
---

<aside class:list={["anime-sticker-card", compact && "compact"]} aria-label={label}>
  <img src="/assets/anime-sticker.svg" alt="动漫风格成长档案贴纸" />
  <div>
    <strong>{label}</strong>
    <span>陪你把每个 checkpoint 存下来。</span>
  </div>
</aside>
